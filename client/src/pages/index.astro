---
// Express demo page — wire each button to the local API (see README).
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Express Backend Demo</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900">
    <main class="mx-auto max-w-lg px-4 py-8">
      <h1 class="text-2xl font-bold text-gray-800">Express Backend Demo</h1>
      <p class="mt-1 text-sm text-gray-500">
        API base: <code class="rounded bg-gray-100 px-1">http://localhost:3001</code>
      </p>

      <div class="mt-8 flex flex-col gap-3">
        <button
          type="button"
          id="btn-get-all"
          class="w-full rounded-md bg-blue-700 py-3 px-4 text-left font-medium text-white hover:bg-blue-600"
        >
          GET /posts
        </button>
        <button
          type="button"
          id="btn-get-one"
          class="w-full rounded-md bg-blue-700 py-3 px-4 text-left font-medium text-white hover:bg-blue-600"
        >
          GET /posts/1
        </button>
      </div>

      <div class="mt-8 border-t border-gray-200 pt-6">
        <p class="mb-2 text-xs font-medium uppercase tracking-wide text-gray-500">POST body</p>
        <div class="space-y-2">
          <input
            id="post-title"
            type="text"
            placeholder="title"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
          />
          <input
            id="post-body"
            type="text"
            placeholder="body"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
          />
          <input
            id="post-userid"
            type="number"
            min="1"
            placeholder="userId"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
            value="1"
          />
        </div>
        <button
          type="button"
          id="btn-post"
          class="mt-3 w-full rounded-md bg-blue-700 py-3 px-4 text-left font-medium text-white hover:bg-blue-600"
        >
          POST /posts
        </button>
      </div>

      <div class="mt-8 border-t border-gray-200 pt-6">
        <p class="mb-2 text-xs font-medium uppercase tracking-wide text-gray-500">PUT body (full replace)</p>
        <div class="space-y-2">
          <input
            id="put-id"
            type="number"
            min="1"
            placeholder="id"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
            value="1"
          />
          <input
            id="put-title"
            type="text"
            placeholder="title"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
          />
          <input
            id="put-body"
            type="text"
            placeholder="body"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
          />
          <input
            id="put-userid"
            type="number"
            min="1"
            placeholder="userId"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
            value="1"
          />
        </div>
        <button
          type="button"
          id="btn-put"
          class="mt-3 w-full rounded-md bg-blue-700 py-3 px-4 text-left font-medium text-white hover:bg-blue-600"
        >
          PUT /posts
        </button>
      </div>

      <div class="mt-8 border-t border-gray-200 pt-6">
        <p class="mb-2 text-xs font-medium uppercase tracking-wide text-gray-500">PATCH (only filled fields)</p>
        <div class="space-y-2">
          <input
            id="patch-id"
            type="number"
            min="1"
            placeholder="id"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
            value="1"
          />
          <input
            id="patch-title"
            type="text"
            placeholder="title (optional)"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
          />
          <input
            id="patch-body"
            type="text"
            placeholder="body (optional)"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
          />
          <input
            id="patch-userid"
            type="text"
            placeholder="userId (optional)"
            class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
          />
        </div>
        <button
          type="button"
          id="btn-patch"
          class="mt-3 w-full rounded-md bg-blue-700 py-3 px-4 text-left font-medium text-white hover:bg-blue-600"
        >
          PATCH /posts
        </button>
      </div>

      <div class="mt-8 border-t border-gray-200 pt-6">
        <p class="mb-2 text-xs font-medium uppercase tracking-wide text-gray-500">DELETE</p>
        <input
          id="delete-id"
          type="number"
          min="1"
          placeholder="id"
          class="block w-full rounded-md border border-gray-300 px-3 py-2 text-sm"
          value="1"
        />
        <button
          type="button"
          id="btn-delete"
          class="mt-3 w-full rounded-md bg-blue-700 py-3 px-4 text-left font-medium text-white hover:bg-blue-600"
        >
          DELETE /posts
        </button>
      </div>

      <section class="mt-10">
        <h2 class="text-lg font-semibold text-gray-800">Response</h2>
        <p id="status-line" class="mt-2 font-mono text-sm text-gray-700">Status: —</p>
        <p class="mt-3 text-sm font-medium text-gray-600">Data</p>
        <pre
          id="output"
          class="mt-1 overflow-x-auto rounded border border-gray-200 bg-gray-50 p-3 font-mono text-xs leading-relaxed text-gray-800"
        ></pre>
      </section>
    </main>

    <script>
      const API = "http://localhost:3001";

      function showResponse(status, data) {
        const statusEl = document.getElementById("status-line");
        const box = document.getElementById("output");
        if (statusEl) statusEl.textContent = "Status: " + status;
        if (!box) return;
        if (data === null || data === undefined) {
          box.textContent = "";
          return;
        }
        box.textContent =
          typeof data === "string" ? data : JSON.stringify(data, null, 2);
      }

      async function parseResponseBody(response) {
        const raw = await response.text();
        if (raw.length === 0) return null;
        try {
          return JSON.parse(raw);
        } catch {
          return raw;
        }
      }

      async function getAllPosts() {
        const response = await fetch(API + "/posts");
        const data = await parseResponseBody(response);
        showResponse(response.status, data);
      }

      async function getPost1() {
        const response = await fetch(API + "/posts/1");
        const data = await parseResponseBody(response);
        showResponse(response.status, data);
      }

      async function createPost() {
        const titleBox = document.getElementById("post-title");
        const bodyBox = document.getElementById("post-body");
        const userIdBox = document.getElementById("post-userid");
        const title = titleBox instanceof HTMLInputElement ? titleBox.value : "";
        const body = bodyBox instanceof HTMLInputElement ? bodyBox.value : "";
        const userId = userIdBox instanceof HTMLInputElement ? Number(userIdBox.value) : NaN;

        const response = await fetch(API + "/posts", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ title, body, userId }),
        });
        const data = await parseResponseBody(response);
        showResponse(response.status, data);
      }

      async function replacePost() {
        const idBox = document.getElementById("put-id");
        const titleBox = document.getElementById("put-title");
        const bodyBox = document.getElementById("put-body");
        const userIdBox = document.getElementById("put-userid");
        const id = idBox instanceof HTMLInputElement ? idBox.value : "";
        const title = titleBox instanceof HTMLInputElement ? titleBox.value : "";
        const body = bodyBox instanceof HTMLInputElement ? bodyBox.value : "";
        const userId = userIdBox instanceof HTMLInputElement ? Number(userIdBox.value) : NaN;

        const response = await fetch(API + "/posts/" + id, {
          method: "PUT",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ title, body, userId }),
        });
        const data = await parseResponseBody(response);
        showResponse(response.status, data);
      }

      async function patchPost() {
        const idBox = document.getElementById("patch-id");
        const titleBox = document.getElementById("patch-title");
        const bodyBox = document.getElementById("patch-body");
        const userIdBox = document.getElementById("patch-userid");
        const id = idBox instanceof HTMLInputElement ? idBox.value : "";

        const payload = {};
        const t = titleBox instanceof HTMLInputElement ? titleBox.value.trim() : "";
        const b = bodyBox instanceof HTMLInputElement ? bodyBox.value.trim() : "";
        const u = userIdBox instanceof HTMLInputElement ? userIdBox.value.trim() : "";
        if (t.length > 0) payload.title = t;
        if (b.length > 0) payload.body = b;
        if (u.length > 0) payload.userId = Number(u);

        const response = await fetch(API + "/posts/" + id, {
          method: "PATCH",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const data = await parseResponseBody(response);
        showResponse(response.status, data);
      }

      async function deletePost() {
        const idBox = document.getElementById("delete-id");
        const id = idBox instanceof HTMLInputElement ? idBox.value : "";
        const response = await fetch(API + "/posts/" + id, {
          method: "DELETE",
        });
        const data = await parseResponseBody(response);
        showResponse(response.status, data);
      }

      function wireButtons() {
        document.getElementById("btn-get-all")?.addEventListener("click", () => {
          getAllPosts().catch((err) => {
            showResponse(0, { error: String(err) });
          });
        });
        document.getElementById("btn-get-one")?.addEventListener("click", () => {
          getPost1().catch((err) => {
            showResponse(0, { error: String(err) });
          });
        });
        document.getElementById("btn-post")?.addEventListener("click", () => {
          createPost().catch((err) => {
            showResponse(0, { error: String(err) });
          });
        });
        document.getElementById("btn-put")?.addEventListener("click", () => {
          replacePost().catch((err) => {
            showResponse(0, { error: String(err) });
          });
        });
        document.getElementById("btn-patch")?.addEventListener("click", () => {
          patchPost().catch((err) => {
            showResponse(0, { error: String(err) });
          });
        });
        document.getElementById("btn-delete")?.addEventListener("click", () => {
          deletePost().catch((err) => {
            showResponse(0, { error: String(err) });
          });
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", wireButtons);
      } else {
        wireButtons();
      }
    </script>
  </body>
</html>
